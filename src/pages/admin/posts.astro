---
import AdminLayout from '../../layouts/AdminLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const blogDir = path.join(process.cwd(), 'src/content/blog');
const files = fs.existsSync(blogDir) ? fs.readdirSync(blogDir).filter(f => f.endsWith('.md')) : [];

const posts = files.map(file => {
  const content = fs.readFileSync(path.join(blogDir, file), 'utf-8');
  const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---/);
  const frontmatter = frontmatterMatch ? frontmatterMatch[1] : '';

  const title = frontmatter.match(/title:\s*"(.+?)"/)?.[1] || file.replace('.md', '');
  const date = frontmatter.match(/date:\s*(.+)/)?.[1]?.trim() || '';
  const draft = /draft:\s*true/.test(frontmatter);
  const description = frontmatter.match(/description:\s*"(.+?)"/)?.[1] || '';
  const tagsMatch = frontmatter.match(/tags:\s*\[(.+?)\]/);
  const tags = tagsMatch ? tagsMatch[1].replace(/"/g, '').split(',').map(t => t.trim()) : [];

  return { slug: file.replace('.md', ''), title, date, draft, description, tags, file };
}).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<AdminLayout title="文章管理 - 后台管理">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-semibold mb-1" style="font-family: var(--font-heading); color: var(--text);">文章管理</h1>
      <p class="text-sm" style="color: var(--text-secondary);">共 {posts.length} 篇文章</p>
    </div>
    <a href="/admin/new" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-medium transition-all duration-300 hover:translate-y-[-1px]" style="background: var(--color-accent); color: var(--color-bg-dark);">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      写新文章
    </a>
  </div>

  <!-- Search -->
  <div class="mb-6">
    <input
      type="text"
      id="search-input"
      placeholder="搜索文章..."
      class="w-full max-w-md px-4 py-2.5 rounded-lg border text-sm outline-none transition-all duration-200 focus:border-[var(--color-accent)]"
      style="background: var(--surface); border-color: var(--border); color: var(--text);"
    />
  </div>

  <!-- Posts Table -->
  <div class="rounded-xl border overflow-hidden" style="background: var(--surface); border-color: var(--border);">
    <table class="w-full" id="posts-table">
      <thead>
        <tr class="border-b" style="border-color: var(--border);">
          <th class="text-left px-5 py-3 text-xs tracking-wider uppercase font-medium" style="color: var(--text-secondary);">标题</th>
          <th class="text-left px-5 py-3 text-xs tracking-wider uppercase font-medium hidden md:table-cell" style="color: var(--text-secondary);">标签</th>
          <th class="text-left px-5 py-3 text-xs tracking-wider uppercase font-medium hidden md:table-cell" style="color: var(--text-secondary);">日期</th>
          <th class="text-left px-5 py-3 text-xs tracking-wider uppercase font-medium" style="color: var(--text-secondary);">状态</th>
          <th class="text-right px-5 py-3 text-xs tracking-wider uppercase font-medium" style="color: var(--text-secondary);">操作</th>
        </tr>
      </thead>
      <tbody>
        {posts.map(post => (
          <tr class="post-row border-b last:border-b-0 transition-colors hover:bg-[var(--surface-2)]" style="border-color: var(--border);" data-title={post.title.toLowerCase()}>
            <td class="px-5 py-4">
              <div class="text-sm font-medium" style="color: var(--text);">{post.title}</div>
              <div class="text-xs mt-0.5 truncate max-w-xs" style="color: var(--text-secondary);">{post.description}</div>
            </td>
            <td class="px-5 py-4 hidden md:table-cell">
              <div class="flex flex-wrap gap-1">
                {post.tags.map(tag => (
                  <span class="text-[10px] px-2 py-0.5 rounded-full" style="background: var(--surface-2); color: var(--text-secondary);">{tag}</span>
                ))}
              </div>
            </td>
            <td class="px-5 py-4 text-xs hidden md:table-cell" style="color: var(--text-secondary);">{post.date}</td>
            <td class="px-5 py-4">
              {post.draft ? (
                <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full" style="background: rgba(201,169,110,0.15); color: var(--color-accent);">
                  <span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-accent);"></span>
                  草稿
                </span>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full" style="background: rgba(34,197,94,0.15); color: #22c55e;">
                  <span class="w-1.5 h-1.5 rounded-full" style="background: #22c55e;"></span>
                  已发布
                </span>
              )}
            </td>
            <td class="px-5 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                <a href={`/admin/edit/${post.slug}`} class="inline-flex items-center gap-1 text-xs px-3 py-1.5 rounded-lg border transition-all duration-200 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]" style="border-color: var(--border); color: var(--text-secondary);">
                  编辑
                </a>
                <button
                  onclick={`if(confirm('确定删除「${post.title}」？此操作不可撤销。')){fetch('/api/posts/${post.slug}',{method:'DELETE'}).then(r=>{if(r.ok)location.reload();else alert('删除失败')})}`}
                  class="inline-flex items-center gap-1 text-xs px-3 py-1.5 rounded-lg border transition-all duration-200 hover:border-red-500 hover:text-red-400"
                  style="border-color: var(--border); color: var(--text-secondary);"
                >
                  删除
                </button>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script is:inline>
    document.getElementById('search-input')?.addEventListener('input', function(e) {
      const q = e.target.value.toLowerCase();
      document.querySelectorAll('.post-row').forEach(row => {
        const title = row.getAttribute('data-title') || '';
        row.style.display = title.includes(q) ? '' : 'none';
      });
    });
  </script>
</AdminLayout>
