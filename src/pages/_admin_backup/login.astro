---
import '../../styles/global.css';

// Handle login POST
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password')?.toString();
  const expected = import.meta.env.ADMIN_PASSWORD || 'admin888';

  if (password === expected) {
    Astro.cookies.set('admin_token', expected, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 7, // 7 days
    });
    return Astro.redirect('/admin');
  }
}

// Already logged in?
const token = Astro.cookies.get('admin_token')?.value;
const expected = import.meta.env.ADMIN_PASSWORD || 'admin888';
if (token === expected) {
  return Astro.redirect('/admin');
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>登录 - 后台管理</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>document.documentElement.setAttribute('data-theme', 'dark');</script>
</head>
<body class="min-h-screen flex items-center justify-center antialiased" style="background: var(--bg);">

  <div class="w-full max-w-sm mx-4">
    <!-- Logo -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl border mb-6" style="background: var(--surface); border-color: var(--border);">
        <span class="text-2xl font-bold" style="font-family: var(--font-heading); color: var(--color-accent);">X</span>
      </div>
      <h1 class="text-2xl font-semibold mb-2" style="font-family: var(--font-heading); color: var(--text);">后台管理</h1>
      <p class="text-sm" style="color: var(--text-secondary);">请输入密码以继续</p>
    </div>

    <!-- Login Form -->
    <form method="POST" class="space-y-5">
      <div>
        <label class="block text-xs tracking-wider uppercase mb-2" style="color: var(--text-secondary);">管理密码</label>
        <input
          type="password"
          name="password"
          required
          autofocus
          placeholder="输入密码..."
          class="w-full px-4 py-3 rounded-lg border text-sm outline-none transition-all duration-200 focus:border-[var(--color-accent)]"
          style="background: var(--surface); border-color: var(--border); color: var(--text);"
        />
      </div>
      <button
        type="submit"
        class="w-full py-3 rounded-lg text-sm font-medium tracking-wider uppercase transition-all duration-300 hover:translate-y-[-1px] hover:shadow-lg"
        style="background: var(--color-accent); color: var(--color-bg-dark);"
      >
        进入后台
      </button>
    </form>

    <div class="text-center mt-8">
      <a href="/" class="text-xs transition-colors hover:text-[var(--color-accent)]" style="color: var(--text-secondary);">
        &larr; 返回网站
      </a>
    </div>
  </div>

</body>
</html>
