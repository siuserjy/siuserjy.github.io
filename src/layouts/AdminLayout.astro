---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '后台管理 - siuser小伟' } = Astro.props;

// Simple auth check via cookie
const token = Astro.cookies.get('admin_token')?.value;
const isAuthed = token === (import.meta.env.ADMIN_PASSWORD || 'admin888');
const isLoginPage = Astro.url.pathname === '/admin/login';

if (!isAuthed && !isLoginPage) {
  return Astro.redirect('/admin/login');
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Sans+SC:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>document.documentElement.setAttribute('data-theme', 'dark');</script>
</head>
<body class="min-h-screen antialiased" style="background: var(--bg); color: var(--text);">

  <!-- Admin Top Bar -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b" style="background: rgba(10,10,11,0.85); backdrop-filter: blur(12px); border-color: var(--border);">
    <div class="flex items-center justify-between h-14 px-6">
      <div class="flex items-center gap-4">
        <a href="/admin" class="flex items-center gap-2.5 text-sm font-medium" style="color: var(--color-accent);">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          控制台
        </a>
        <span class="text-xs px-2 py-0.5 rounded" style="background: var(--surface-2); color: var(--text-secondary);">Admin</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" target="_blank" class="text-xs transition-colors hover:text-[var(--color-accent)]" style="color: var(--text-secondary);">
          查看网站 &rarr;
        </a>
        <form method="POST" action="/api/auth/logout" class="inline">
          <button type="submit" class="text-xs transition-colors hover:text-red-400" style="color: var(--text-secondary);">
            退出登录
          </button>
        </form>
      </div>
    </div>
  </header>

  <!-- Sidebar + Content -->
  <div class="flex pt-14 min-h-screen">
    <!-- Sidebar -->
    <aside class="fixed left-0 top-14 bottom-0 w-56 border-r overflow-y-auto" style="background: var(--surface); border-color: var(--border);">
      <nav class="p-4 space-y-1">
        <p class="text-[10px] tracking-[0.15em] uppercase mb-3 px-3" style="color: var(--text-secondary);">内容管理</p>
        <a href="/admin" class="admin-nav-item flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-all duration-200 hover:bg-[var(--surface-2)]" style="color: var(--text-secondary);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
          </svg>
          仪表盘
        </a>
        <a href="/admin/posts" class="admin-nav-item flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-all duration-200 hover:bg-[var(--surface-2)]" style="color: var(--text-secondary);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          文章管理
        </a>
        <a href="/admin/new" class="admin-nav-item flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-all duration-200 hover:bg-[var(--surface-2)]" style="color: var(--text-secondary);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          写新文章
        </a>

        <div class="pt-4">
          <p class="text-[10px] tracking-[0.15em] uppercase mb-3 px-3" style="color: var(--text-secondary);">快捷操作</p>
          <a href="/admin/new" class="flex items-center gap-2 mx-2 px-4 py-2.5 rounded-lg text-xs font-medium transition-all duration-300 hover:translate-y-[-1px]" style="background: var(--color-accent); color: var(--color-bg-dark);">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
            </svg>
            开始写作
          </a>
        </div>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="ml-56 flex-1 p-8">
      <slot />
    </main>
  </div>

  <!-- Active nav highlight -->
  <script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.admin-nav-item').forEach(el => {
        const href = el.getAttribute('href');
        const isActive = (href === '/admin' && path === '/admin') ||
                         (href === '/admin/posts' && path.startsWith('/admin/posts')) ||
                         (href === '/admin/new' && path === '/admin/new');
        if (isActive) {
          el.style.color = 'var(--color-accent)';
          el.style.background = 'var(--surface-2)';
        }
      });
    })();
  </script>
</body>
</html>
