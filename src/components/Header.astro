---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md" style="background: color-mix(in srgb, var(--bg) 80%, transparent);">
  <nav class="mx-auto flex items-center justify-between px-6 py-4" style="max-width: var(--container-max);">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2">
      <span class="text-lg font-semibold tracking-tight" style="color: var(--text); font-family: var(--font-heading);">
        XingHui
      </span>
      <span class="text-xs tracking-widest uppercase" style="color: var(--color-accent);">
        Blog
      </span>
    </a>

    <!-- Navigation -->
    <div class="flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            "text-sm tracking-wide transition-colors duration-200 hover:text-[var(--color-accent)]",
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? "text-[var(--color-accent)]"
              : "text-[var(--text-secondary)]"
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- Theme Toggle -->
      <button
        onclick="toggleTheme()"
        class="p-2 rounded-full transition-colors duration-200 hover:bg-[var(--surface-2)]"
        aria-label="切换主题"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-4 h-4 dark-icon" style="color: var(--text-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-4 h-4 light-icon" style="color: var(--text-secondary); display: none;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script is:inline>
  function updateIcons() {
    const theme = document.documentElement.getAttribute('data-theme');
    document.querySelectorAll('.dark-icon').forEach(el => el.style.display = theme === 'dark' ? 'block' : 'none');
    document.querySelectorAll('.light-icon').forEach(el => el.style.display = theme === 'light' ? 'block' : 'none');
  }
  updateIcons();

  const observer = new MutationObserver(updateIcons);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
